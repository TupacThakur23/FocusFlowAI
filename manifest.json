{
    "manifest_version": 3,
    "name": "FocusFlow AI",
    "version": "1.0",
    "description":"AI Research Workplace",

    "permissions":["storage","activeTab","scripting"],

    "background":{
        "service_worker":"background.js"
    },
    "action":{
        "default_popup":"popup.html"

    },

    "content_scripts":[
        {
            "matches":["<all_urls>"],
            "js":["content.js"]
        }
    ]
}